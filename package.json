{
  "name": "jarvis-node-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start --dev-client",
    "start:go": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios --device \"iPhone 17 Pro Max\"",
    "ios:pick": "expo run:ios --device",
    "web": "expo start --web",
    "build:dev:ios": "eas build --profile development --platform ios",
    "build:dev:android": "eas build --profile development --platform android",
    "build:dev:local": "npx expo run:ios --device \"iPhone 17 Pro Max\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@bacons/apple-targets": "^4.0.7",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/slider": "^5.2.0",
    "@react-navigation/bottom-tabs": "^7.18.8",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.17.10",
    "@tanstack/react-query": "^5.101.2",
    "axios": "^1.18.1",
    "expo": "~54.0.33",
    "expo-av": "~16.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-camera": "~17.0.0",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-network": "~8.0.8",
    "expo-notifications": "~0.32.16",
    "expo-secure-store": "~15.0.0",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "jarvis-crypto": "file:./modules/jarvis-crypto",
    "react": "19.2.7",
    "react-native": "0.86.0",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-paper": "^5.15.3",
    "react-native-qrcode-svg": "^6.3.14",
    "react-native-reanimated": "~4.5.1",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-screens": "~4.26.1",
    "react-native-svg": "15.15.5",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.10.2",
    "react-native-zeroconf": "^0.14.0"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.17",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "@testing-library/jest-native/extend-expect",
      "<rootDir>/jest.setup.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(jest-)?react-native|@react-native|@react-navigation|@react-native-community|expo(nent)?|@expo(nent)?|@expo-google-fonts|@unimodules|unimodules|sentry-expo|native-base|react-native-paper)"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.ts?(x)"
    ]
  },
  "private": true
}
