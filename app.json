{
  "expo": {
    "name": "Jarvis Automation",
    "slug": "jarvis-node-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d0d2b"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jarvis.nodemobile",
        "buildNumber": "10",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera access is required to scan QR codes for node pairing",
        "NSLocalNetworkUsageDescription": "Jarvis needs local network access to discover your self-hosted server.",
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        },
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.683175564329-24fi9h6hck48hfrbjhb24vf12680e5ec"
            ]
          }
        ]
      }
    },
    "android": {
      "package": "com.jarvis.nodemobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d0d2b"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera to scan QR codes"
        }
      ],
      "expo-secure-store",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "db3e1a49-edf0-463d-bd7d-0b40d13caf83"
      }
    }
  }
}
