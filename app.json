{
  "expo": {
    "name": "Jarvis Automation",
    "slug": "jarvis-node-mobile",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d0d2b"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jarvis.nodemobile",
      "buildNumber": "10",
      "appleTeamId": "8H5GA7SX77",
      "associatedDomains": [
        "applinks:docs.jarvisautomation.dev"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "Camera access is required to scan QR codes for node pairing",
        "NSMicrophoneUsageDescription": "Microphone access is required to send voice commands to Jarvis.",
        "NSLocalNetworkUsageDescription": "Jarvis needs local network access to discover your self-hosted server.",
        "NSBonjourServices": [
          "_jarvis-config._tcp"
        ],
        "INAlternativeAppNames": [
          {
            "INAlternativeAppName": "Jarvis"
          },
          {
            "INAlternativeAppName": "Jarvis app"
          }
        ],
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSAllowsLocalNetworking": true
        },
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.683175564329-24fi9h6hck48hfrbjhb24vf12680e5ec",
              "com.jarvis.app"
            ]
          }
        ]
      }
    },
    "android": {
      "package": "com.jarvis.nodemobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d0d2b"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.CHANGE_WIFI_MULTICAST_STATE",
        "android.permission.ACCESS_WIFI_STATE",
        "android.permission.USE_BIOMETRIC"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera to scan QR codes"
        }
      ],
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Allow Jarvis to use Face ID to unlock the app."
        }
      ],
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      "./plugins/withJarvisAppIntents.js",
      "@bacons/apple-targets"
    ],
    "extra": {
      "eas": {
        "projectId": "db3e1a49-edf0-463d-bd7d-0b40d13caf83"
      }
    }
  }
}
